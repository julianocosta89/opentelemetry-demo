{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=next dev",
    "build": "next build",
    "start": "node server.js",
    "lint": "next lint",
    "cy:open": "cypress open",
    "grpc:generate": "mkdir -p ./protos && protoc -I ./pb  --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_opt=esModuleInterop=true --ts_proto_out=./protos --ts_proto_opt=outputServices=grpc-js demo.proto"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@grpc/grpc-js": "1.14.3",
    "@openfeature/flagd-provider": "0.15.0",
    "@openfeature/flagd-web-provider": "0.7.4",
    "@openfeature/react-sdk": "1.2.1",
    "@tanstack/react-query": "5.99.0",
    "cookies-next": "6.1.1",
    "currency-symbol-map": "5.1.0",
    "dotenv": "17.4.2",
    "dotenv-expand": "12.0.3",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sharp": "0.34.5",
    "styled-components": "6.4.0",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/styled-components": "5.1.36",
    "@typescript-eslint/eslint-plugin": "8.58.2",
